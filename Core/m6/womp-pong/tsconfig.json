{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src/backend",
    "outDir": "dist/backend",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/backend/**/*", "src/frontend/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/frontend"
  ]
}
