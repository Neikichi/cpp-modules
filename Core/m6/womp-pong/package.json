{
	"name": "ft_transcendence",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev:vite": "vite",
		"build:vite": "vite build",
		"build:services": "tsc -p .",
		"dev:local": "npm-run-all --parallel dev:vite dev:services:watch",
		"dev:services:watch": "tsc -p . --watch",
		"dev:services:start": "npm-run-all --parallel dev:login dev:register dev:game dev:chat dev:gateway",
		"dev:login": "nodemon --watch dist/backend/services/login --exec \"node dist/backend/services/login/server.js\"",
		"dev:register": "nodemon --watch dist/backend/services/register --exec \"node dist/backend/services/register/server.js\"",
		"dev:game": "nodemon --watch dist/backend/services/game --exec \"node dist/backend/services/game/server.js\"",
		"dev:chat": "nodemon --watch dist/backend/services/chat --exec \"node dist/backend/services/chat/server.js\"",
		"dev:gateway": "nodemon --watch dist/backend/services/gateway --exec \"node dist/backend/services/gateway/server.js\"",
		"docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
		"docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
		"docker:prod": "cd src && docker-compose up --build",
		"docker:prod:down": "cd src && docker-compose down",
		"prod:build": "npm run build:services && npm run build:vite",
		"prod:start": "npm run docker:prod",
		"db:seed": "npm run build:services && node dist/backend/db/seed.js",
		"db:reset": "rm -f data/womp-pong.db && npm run db:seed",
		"clean": "rm -rf dist node_modules package-lock.json",
		"clean:install": "rm -rf node_modules package-lock.json && npm install",
		"postinstall": "patch-package || true"
	},
	"dependencies": {
		"@fastify/cors": "^11.1.0",
		"@tailwindcss/vite": "^4.1.16",
		"bcrypt": "^5.1.1",
		"better-sqlite3": "^11.7.0",
		"fastify": "^5.6.1",
		"jsonwebtoken": "^9.0.2",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-router-dom": "^7.0.2",
		"tailwindcss": "^4.1.16"
	},
	"devDependencies": {
		"@types/bcrypt": "^5.0.2",
		"@types/better-sqlite3": "^7.6.12",
		"@types/jsonwebtoken": "^9.0.7",
		"@types/node": "^22.18.13",
		"@types/react": "^19.0.4",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^5.1.0",
		"nodemon": "^3.1.10",
		"npm-run-all": "^4.1.5",
		"patch-package": "^8.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.1.12"
	}
}
