RPN::RPN() {}

RPN::RPN(const RPN& other) : std::stack<std::string>(other) {}

RPN& RPN::operator=(const RPN& other) {
	if (this != &other) {
		std::stack<std::string>::operator=(other);
	}
	return *this;
}

RPN::~RPN() {}

RPN::iterator RPN::begin() { return this->c.begin(); }

RPN::iterator RPN::end() { return this->c.end(); }

RPN::const_iterator RPN::begin() const { return this->c.begin(); }

RPN::const_iterator RPN::end() const { return this->c.end(); }

