Btc::Btc() {}

Btc::Btc(const Btc& other) : _db(other._db) {}

Btc& Btc::operator=(const Btc& other) {
	if (this != &other) {
		this->_db = other._db;
	}
	return *this;
}

Btc::~Btc() {}

static std::string& ft_strtrim(std::string& s) {
	std::size_t st = s.find_first_not_of(WHITESPACES),
				end = s.find_last_not_of(WHITESPACES);

	if(st == std::string::npos) {
		s.clear();
		return s;
	}

	s.erase(end + 1);
	s.erase(0, st);
	return s;
}

static std::vector<std::string> ft_split(const std::string& s, const std::string& c) {
	std::vector<std::string> arr;
	std::string word;
	std::size_t st = 0, end;

	while ((end = s.find(c, st)) != std::string::npos) {
		word = s.substr(st, end - st);
		if (!word.empty()) {
			ft_strtrim(word);
			arr.push_back(word);
		}
		st = end + c.length();
	}
	word = s.substr(st);
	if (!word.empty()) {
		ft_strtrim(word);
		arr.push_back(word);
	}
	return arr;
}

static int strToInt(std::string& s) {
	while (s.find("-") != std::string::npos) {
		std::size_t idx = s.find("-");
		s.erase(idx, 1);
	}
	if (s.length() != 8)
		return -1;
	for (std::size_t i = 0; i < 8; i++) {
		if (!std::isdigit(static_cast<unsigned char>(s[i])))
			return -1;
	}
	return std::atoi(s.c_str());
}

static float strToFloat(const std::string& s) {
	char *end;
	double val = std::strtod(s.c_str(), &end);

	if (*end || val < 0.0)
		return -1.0f;
	if (val > static_cast<double>(INT_MAX))
		return -2.0f;
	return static_cast<float>(val);
}

static int getDay(int yy, int mm) {
	static const int days[] = {
		0, 31, 28, 31, 30, 31, 30,
		31, 31, 30, 31, 30, 31
	};

	if (mm == 2 &&
		((yy % 4 == 0 && yy % 100 != 0) || (yy % 400 == 0)))
		return 29;
	return days[mm];

}

bool Btc::parseDate(int date) const {
	int yy = date / 10000;
	int mm = (date / 100) % 100;
	int dd = date % 100;

	if (yy < 1 || (mm < 1 || mm > 12))
		return false;
	return dd >= 1 && dd <= getDay(yy, mm);
	
}

